span class=\"line\">46</span><br><span class=\"line\">47</span><br><span class=\"line\">48</span><br><span class=\"line\">49</span><br><span class=\"line\">50</span><br><span class=\"line\">51</span><br><span class=\"line\">52</span><br><span class=\"line\">53</span><br><span class=\"line\">54</span><br><span class=\"line\">55</span><br><span class=\"line\">56</span><br><span class=\"line\">57</span><br><span class=\"line\">58</span><br><span class=\"line\">59</span><br><span class=\"line\">60</span><br><span class=\"line\">61</span><br><span class=\"line\">62</span><br><span class=\"line\">63</span><br><span class=\"line\">64</span><br><span class=\"line\">65</span><br><span class=\"line\">66</span><br><span class=\"line\">67</span><br><span class=\"line\">68</span><br><span class=\"line\">69</span><br><span class=\"line\">70</span><br><span class=\"line\">71</span><br><span class=\"line\">72</span><br><span class=\"line\">73</span><br><span class=\"line\">74</span><br><span class=\"line\">75</span><br><span class=\"line\">76</span><br><span class=\"line\">77</span><br></pre></td><td class=\"code\"><pre><span class=\"line\"><span class=\"meta\">#<span class=\"keyword\">include</span><span class=\"string\">&lt;bits/stdc++.h&gt;</span></span></span><br><span class=\"line\"><span class=\"keyword\">using</span> <span class=\"keyword\">namespace</span> std;</span><br><span class=\"line\"><span class=\"type\">const</span> <span class=\"type\">int</span> N = <span class=\"number\">120</span>;</span><br><span class=\"line\"><span class=\"type\">const</span> <span class=\"type\">long</span> <span class=\"type\">long</span> mod = <span class=\"number\">1e9</span><span class=\"number\">+7</span>;</span><br><span class=\"line\"><span class=\"type\">int</span> n,m,top,stk[N],idx,x[N];</span><br><span class=\"line\"><span class=\"keyword\">struct</span> <span class=\"title class_\">Node</span>&#123;</span><br><span class=\"line\">    <span class=\"type\">int</span> type;</span><br><span class=\"line\">    <span class=\"type\">long</span> <span class=\"type\">long</span> l,r;</span><br><span class=\"line\">    <span class=\"type\">long</span> <span class=\"type\">long</span> value;</span><br><span class=\"line\">&#125;;</span><br><span class=\"line\">Node nodes[N*N];</span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"function\"><span class=\"type\">long</span> <span class=\"type\">long</span> <span class=\"title\">get_value</span><span class=\"params\">(<span class=\"type\">int</span> u)</span></span>&#123;<span class=\"comment\">//求nodes[u]的值（假设此时x[i]已全部给出</span></span><br><span class=\"line\">    <span class=\"keyword\">if</span>(nodes[u].type == <span class=\"number\">1</span>)&#123;</span><br><span class=\"line\">        <span class=\"keyword\">if</span>(nodes[u].value == <span class=\"number\">1</span>) <span class=\"keyword\">return</span> (<span class=\"built_in\">get_value</span>(nodes[u].l)+<span class=\"built_in\">get_value</span>(nodes[u].r)+mod)%mod;</span><br><span class=\"line\">        <span class=\"keyword\">else</span> <span class=\"keyword\">if</span>(nodes[u].value == <span class=\"number\">2</span>) <span class=\"built_in\">return</span> (<span class=\"built_in\">get_value</span>(nodes[u].l)-<span class=\"built_in\">get_value</span>(nodes[u].r)+mod)%mod;</span><br><span class=\"line\">        <span class=\"keyword\">else</span> <span class=\"built_in\">return</span> (<span class=\"built_in\">get_value</span>(nodes[u].l)*<span class=\"built_in\">get_value</span>(nodes[u].r)+mod)%mod;</span><br><span class=\"line\">    &#125;</span><br><span class=\"line\">    <span class=\"keyword\">else</span> <span class=\"keyword\">if</span>(nodes[u].type == <span class=\"number\">2</span>) <span class=\"built_in\">return</span> (x[nodes[u].value]+mod)%mod;</span><br><span class=\"line\">    <span class=\"keyword\">else</span> <span class=\"built_in\">return</span> (nodes[u].value+mod)%mod;</span><br><span class=\"line\">&#125;</span><br><span class=\"line\"><span class=\"function\"><span class=\"type\">long</span> <span class=\"type\">long</span> <span class=\"title\">deriv</span><span class=\"params\">(<span class=\"type\">int</span> u,<span class=\"type\">int</span> k)</span></span>&#123;<span class=\"comment\">//对第k个变量求偏导，并把值代入；</span></span><br><span class=\"line\">    <span class=\"keyword\">if</span>(nodes[u].type == <span class=\"number\">1</span>)&#123;</span><br><span class=\"line\">        <span class=\"type\">long</span> <span class=\"type\">long</span> a = <span class=\"built_in\">deriv</span>(nodes[u].l,k), b = <span class=\"built_in\">deriv</span>(nodes[u].r,k);</span><br><span class=\"line\">            <span class=\"keyword\">if</span>(nodes[u].value == <span class=\"number\">1</span>) <span class=\"keyword\">return</span> (a+b+mod)%mod;</span><br><span class=\"line\">            <span class=\"keyword\">else</span> <span class=\"keyword\">if</span>(nodes[u].value == <span class=\"number\">2</span>) <span class=\"built_in\">return</span> (a-b+mod)%mod;</span><br><span class=\"line\">            <span class=\"keyword\">else</span>&#123;</span><br><span class=\"line\">                <span class=\"type\">long</span> <span class=\"type\">long</span> a0 = (<span class=\"built_in\">get_value</span>(nodes[u].l)+mod)%mod, b0 = (<span class=\"built_in\">get_value</span>(nodes[u].r)+mod)%mod;</span><br><span class=\"line\">                <span class=\"keyword\">return</span> (a*b0 + b*a0)%mod;</span><br><span class=\"line\">            &#125;</span><br><span class=\"line\"></span><br><span class=\"line\">    &#125;</span><br><span class=\"line\">    <span class=\"keyword\">else</span> <span class=\"keyword\">if</span>(nodes[u].type == <span class=\"number\">2</span>)&#123;</span><br><span class=\"line\">        <span class=\"keyword\">if</span>(nodes[u].value == k) <span class=\"keyword\">return</span> <span class=\"number\">1</span>;</span><br><span class=\"line\">        <span class=\"keyword\">else</span> <span class=\"keyword\">return</span> <span class=\"number\">0</span>;</span><br><span class=\"line\">    &#125;</span><br><span class=\"line\">    <span class=\"keyword\">else</span> <span class=\"keyword\">return</span> <span class=\"number\">0</span>;</span><br><span class=\"line\">&#125;</span><br><span class=\"line\"><span class=\"function\"><span class=\"type\">int</span> <span class=\"title\">main</span><span class=\"params\">()</span></span>&#123;</span><br><span class=\"line\">    cin &gt;&gt; n &gt;&gt; m;</span><br><span class=\"line\">    cin.<span class=\"built_in\">ignore</span>();</span><br><span class=\"line\">    string line;</span><br><span class=\"line\">    <span class=\"built_in\">getline</span>(cin, line);</span><br><span class=\"line\">    <span class=\"function\">stringstream <span class=\"title\">ss</span><span class=\"params\">(line)</span></span>;</span><br><span class=\"line\">    string s;</span><br><span class=\"line\">    <span class=\"keyword\">while</span>(ss &gt;&gt; s)&#123;</span><br><span class=\"line\">        idx ++ ;</span><br><span class=\"line\">        <span class=\"keyword\">if</span>(s==<span class=\"string\">&quot;+&quot;</span>||s==<span class=\"string\">&quot;-&quot;</span>||s==<span class=\"string\">&quot;*&quot;</span>)&#123;</span><br><span class=\"line\">            nodes[idx].type = <span class=\"number\">1</span>;</span><br><span class=\"line\">            <span class=\"keyword\">if</span>(s==<span class=\"string\">&quot;+&quot;</span>) nodes[idx].value = <span class=\"number\">1</span>;</span><br><span class=\"line\">            <span class=\"keyword\">else</span> <span class=\"keyword\">if</span>(s==<span class=\"string\">&quot;-&quot;</span>) nodes[idx].value = <span class=\"number\">2</span>;</span><br><span class=\"line\">            <span class=\"keyword\">else</span> nodes[idx].value = <span class=\"number\">3</span>;</span><br><span class=\"line\">            nodes[idx].l = stk[top<span class=\"number\">-2</span>];</span><br><span class=\"line\">            nodes[idx].r = stk[top<span class=\"number\">-1</span>];</span><br><span class=\"line\">            top -= <span class=\"number\">2</span>;</span><br><span class=\"line\">            stk[top++] = idx;</span><br><span class=\"line\">        &#125;</span><br><span class=\"line\">        <span class=\"keyword\">else</span> <span class=\"keyword\">if</span>(s[<span class=\"number\">0</span>]==<span class=\"string\">&#x27;x&#x27;</span>)&#123;</span><br><span class=\"line\">            <span class=\"type\">long</span> <span class=\"type\">long</span> a = <span class=\"built_in\">atoll</span>((s.<span class=\"built_in\">substr</span>(<span class=\"number\">1</span>,s.<span class=\"built_in\">size</span>()<span class=\"number\">-1</span>)).<span class=\"built_in\">c_str</span>());</span><br><span class=\"line\">            stk[top++] = idx;</span><br><span class=\"line\">            nodes[idx].type = <span class=\"number\">2</span>;</span><br><span class=\"line\">            nodes[idx].value = a;<span class=\"comment\">//存全局变量的下标</span></span><br><span class=\"line\">        &#125;</span><br><span class=\"line\">        <span class=\"keyword\">else</span>&#123;</span><br><span class=\"line\">            stk[top++] = idx;</span><br><span class=\"line\">            nodes[idx].type = <span class=\"number\">3</span>;</span><br><span class=\"line\">            nodes[idx].value = <span class=\"built_in\">atoll</span>(s.<span class=\"built_in\">c_str</span>());</span><br><span class=\"line\">        &#125;</span><br><span class=\"line\"></span><br><span class=\"line\">    &#125;</span><br><span class=\"line\">    <span class=\"type\">int</span> root = stk[top<span class=\"number\">-1</span>];</span><br><span class=\"line\">    <span class=\"keyword\">for</span>(<span class=\"type\">int</span> i=<span class=\"number\">0</span>;i&lt;m;i++)&#123;</span><br><span class=\"line\">        <span class=\"type\">int</span> a;cin&gt;&gt;a;</span><br><span class=\"line\">        <span class=\"keyword\">for</span>(<span class=\"type\">int</span> j=<span class=\"number\">1</span>;j&lt;=n;j++) &#123;<span class=\"type\">int</span> t;cin&gt;&gt;t;x[j]=t;&#125;</span><br><span class=\"line\">        cout&lt;&lt;<span class=\"built_in\">deriv</span>(root,a)&lt;&lt;endl;</span><br><span class=\"line\">    &#125;</span><br><span class=\"line\">&#125;</span><br></pre></td></tr></table></figure>\n\n<h1 id=\"一些细节\"><a href=\"#一些细节\" class=\"headerlink\" title=\"一些细节\"></a>一些细节</h1><h2 id=\"字符串读取与处理\"><a href=\"#字符串读取与处理\" class=\"headerlink\" title=\"字符串读取与处理\"></a>字符串读取与处理</h2><figure class=\"highlight cpp\"><table><tr><td class=\"gutter\"><pre><span class=\"line\">1</span><br><span class=\"line\">2</span><br><span class=\"line\">3</span><br><span class=\"line\">4</span><br><span class=\"line\">5</span><br></pre></td><td class=\"code\"><pre><span class=\"line\">string line;</span><br><span class=\"line\"><span class=\"built_in\">getline</span>(cin, line);</span><br><span class=\"line\"><span class=\"function\">stringstream <span class=\"title\">ss</span><span class=\"params\">(line)</span></span>;</span><br><span class=\"line\">string s;</span><br><span class=\"line\"><span class=\"keyword\">while</span>(ss &gt;&gt; s)&#123;code&#125;</span><br></pre></td></tr></table></figure>\n<p>此处，</p>\n<ol>\n<li><p><code>getline(cin, line);</code><br>从标准输入cin中读取一整行文本，并存入字符串变量line中</p>\n</li>\n<li><p><code>stringstream ss(line);</code><br>创建一个stringstream类型的变量ss，用line去初始化</p>\n</li>\n</ol>\n","feature":true,"text":"题目链接 题解1234567891011121314151617181920212223242526272829303132333435363738394041...","permalink":"/post/梯度求解：树、字符串","photos":[],"count_time":{"symbolsCount":"2.9k","symbolsTime":"3 mins."},"categories":[],"tags":[{"name":"DFS","slug":"DFS","count":6,"path":"api/tags/DFS.json"}],"toc":"<ol class=\"toc\"><li class=\"toc-item toc-level-1\"><a class=\"toc-link\" href=\